# 复制为 .env 并填好（Node / VPS / Docker 部署用；Workers 用 wrangler secret）。

# 【必填】手机与本后端之间的共享密钥。随便生成一个长随机串，
#         同一个值要填到 APP 设置页的「中继密钥」里。两端一致才放行。
#   生成示例：openssl rand -hex 32
RELAY_SECRET=

# 端口（默认 8787）
PORT=8787

# outbox 存储：memory（默认，重启清空）/ sqlite（持久，需 better-sqlite3）
RELAY_STORE=memory
# RELAY_SQLITE_PATH=./outbox.db

# 【可选】Web Push (VAPID)。不填则不发推送，手机靠轮询拉取（最通用，大陆也能用）。
#   只用 web-push 这个 npm 包来「生成密钥」，运行时不依赖它（推送是纯 Web Crypto 实现，Workers/Node 通用）：
#     npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# 【可选】iOS APNs 推送（App 完全关闭也能弹通知）。需 Apple 开发者账号。
#   在 Apple Developer → Keys 建一个 APNs Auth Key，下载 .p8。
#   APNS_KEY_P8：.p8 文件全文（多行，含 BEGIN/END PRIVATE KEY）；CF 用 wrangler secret put 时直接粘贴
#   APNS_KEY_ID：该 Key 的 Key ID（10 位）
#   APNS_TEAM_ID：开发者 Team ID（10 位，Membership 页可查）
#   APNS_BUNDLE_ID：App 的 Bundle ID，如 app.nuojiji
#   APNS_PRODUCTION：正式版/TestFlight 填 1；Xcode 直连真机调试填 0(sandbox)
APNS_KEY_P8=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRODUCTION=1
